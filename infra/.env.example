# Opcional: infra/.env solo si quieres anular el puerto del host.
# Por defecto el compose ya publica Timescale en 5433 (evita choque con postgres nativo en Windows :5432).
# Para usar el host :5432: POSTGRES_PORT=5432
# POSTGRES_PORT=5432

# MLflow (tracking): host 5000
# MLFLOW_PORT=5000

# Prometheus UI: host 9091 → contenedor 9090
# PROMETHEUS_PORT=9091

# Grafana: host 3001 → contenedor 3000 (no chocar con Next.js en 3000)
# GRAFANA_PORT=3001
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
