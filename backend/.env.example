# Copiar a .env (UTF-8). Ese archivo NO va a git — aquí sí van credenciales de desarrollo.
# El código (app/core/config.py) NO trae DSN ni JWT por defecto.
# Alembic (sync, SQLAlchemy + psycopg v3).
# El puerto debe coincidir con infra/docker-compose.yml (variable POSTGRES_PORT en infra/.env).
# En Windows con PostgreSQL nativo en 5432, suele usarse POSTGRES_PORT=5433 → 127.0.0.1:5433 aquí.
DATABASE_URL=postgresql+psycopg://telema:telema_dev@127.0.0.1:5433/telema

# FastAPI (asyncpg):
DATABASE_URL_ASYNC=postgresql+asyncpg://telema:telema_dev@127.0.0.1:5433/telema

# Alembic: Postgres local sin Timescale (p. ej. instalador Windows) → 0. Docker TimescaleDB → omitir o 1.
# TELEMA_USE_TIMESCALEDB=0

# Kafka (compose en infra/docker-compose.yml). Desde Windows/Mac hacia el broker mapeado:
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
# KAFKA_TOPIC_RAW_TELEMETRY=raw.telemetry
# KAFKA_CONSUMER_GROUP=telema-telemetry-writer

# Simulador: UUIDs que existan en `vehicles` tras seed_demo (coma-separados, sin espacios).
# SIM_VEHICLE_IDS=00000000-0000-4000-8000-000000000011,00000000-0000-4000-8000-000000000012,00000000-0000-4000-8000-000000000013
# SIM_SCENARIO=normal

# Optional: CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Auth (JWT)
# IMPORTANTE: cambia JWT_SECRET en entornos reales.
JWT_SECRET=CHANGE_ME_DEV_ONLY
JWT_ALGORITHM=HS256
# Duración del access JWT (min). Front renueva con POST /auth/refresh cada ACCESS_REFRESH_INTERVAL_MS (7 min).
JWT_ACCESS_MINUTES=7
JWT_REFRESH_DAYS=14
# Cookie para el access token (además del header Authorization: Bearer ...)
AUTH_COOKIE_NAME=telema_access
# En producción HTTPS: 1. En local: 0.
AUTH_COOKIE_SECURE=0
# lax / strict / none
AUTH_COOKIE_SAMESITE=lax

# MLflow (scripts/train_iforest_mlflow.py) — levantar servicio `mlflow` en docker-compose.
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Detección de anomalías (script run_anomaly_detection.py): lista opcional de UUIDs separados por coma.
# TELEMA_ANOMALY_VEHICLE_IDS=00000000-0000-4000-8000-000000000011

# --- Ingesta laboratorio (acelerómetro / DAQ) → POST /ingest/telemetry ---
# Genera una clave larga; el script daq_to_telema.py la envía en header X-Telema-Ingest-Key.
TELEMA_INGEST_API_KEY=cambia_esto_por_una_clave_larga_aleatoria
# Vehículo principal (prueba 01): GV-PRB-01
# TELEMA_VEHICLE_ID=00000000-0000-4000-8000-000000000011
# Carpeta con los 13 .mat del profesor (import masivo):
# TELEMA_MATLAB_DIR=C:\Users\ASUS\Desktop\Datos

# --- Correo automático al crear ticket (POST /tickets/from-anomaly) ---
# SMTP_ENABLED=0
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASSWORD=contraseña_de_aplicacion
# SMTP_FROM=Telema <tu_correo@gmail.com>
# SMTP_USE_TLS=1
# TICKET_NOTIFY_EMAILS=tecnico@empresa.com,jefe@empresa.com
# FRONTEND_BASE_URL=http://127.0.0.1:3000
