# Copy to .env — save file as UTF-8 (VS Code: bottom bar encoding).
# Alembic (sync, SQLAlchemy + psycopg v3).
# El puerto debe coincidir con infra/docker-compose.yml (variable POSTGRES_PORT en infra/.env).
# En Windows con PostgreSQL nativo en 5432, suele usarse POSTGRES_PORT=5433 → 127.0.0.1:5433 aquí.
DATABASE_URL=postgresql+psycopg://telema:telema_dev@127.0.0.1:5433/telema

# FastAPI (asyncpg):
DATABASE_URL_ASYNC=postgresql+asyncpg://telema:telema_dev@127.0.0.1:5433/telema

# Alembic: Postgres local sin Timescale (p. ej. instalador Windows) → 0. Docker TimescaleDB → omitir o 1.
# TELEMA_USE_TIMESCALEDB=0

# Kafka (compose en infra/docker-compose.yml). Desde Windows/Mac hacia el broker mapeado:
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
# KAFKA_TOPIC_RAW_TELEMETRY=raw.telemetry
# KAFKA_CONSUMER_GROUP=telema-telemetry-writer

# Simulador: UUIDs que existan en `vehicles` tras seed_demo (coma-separados, sin espacios).
# SIM_VEHICLE_IDS=00000000-0000-4000-8000-000000000011,00000000-0000-4000-8000-000000000012,00000000-0000-4000-8000-000000000013
# SIM_SCENARIO=normal

# Optional: CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
